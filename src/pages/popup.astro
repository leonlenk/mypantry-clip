---
import "../styles/global.scss";
import "../styles/popup.scss";
import MainView from "../components/popup/MainView.astro";
import SetupView from "../components/popup/SetupView.astro";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Recipe AI - Action Panel</title>
  </head>
  <body>
    <MainView />
    <SetupView />

    <script>
      import { decryptData, encryptData } from "../utils/crypto";
      import {
        checkJsonLd,
        extractWithReadability,
        extractRecipeWithClaude,
      } from "../utils/parser";
      import { saveRecipeLocally } from "../utils/db";

      // ------------- View State -------------
      const mainView = document.getElementById("main-view");
      const setupView = document.getElementById("setup-view");
      const settingsBtn = document.getElementById("settings-btn");
      const closeSettingsBtn = document.getElementById("close-settings-btn");

      async function showSetup() {
        mainView?.classList.add("hidden");
        setupView?.classList.remove("hidden");

        // Auto-populate logic
        if (typeof chrome !== "undefined" && chrome.storage) {
          const data = await chrome.storage.local.get([
            "plaintextApiKey",
            "encryptedApiKey",
            "llmProvider",
            "llmModel",
          ]);

          const providerSelectEl = document.getElementById(
            "provider-select"
          ) as HTMLSelectElement;
          const apiKeyInputEl = document.getElementById(
            "api-key"
          ) as HTMLInputElement;
          const fetchBtnEl = document.getElementById("fetch-models-btn");
          const modelStatusEl = document.getElementById("model-status");
          const modelSelectEl = document.getElementById(
            "model-select"
          ) as HTMLSelectElement;

          if (data.llmProvider && providerSelectEl) {
            providerSelectEl.value = String(data.llmProvider);
          }

          if (data.plaintextApiKey || data.encryptedApiKey) {
            if (apiKeyInputEl) {
              apiKeyInputEl.value = "••••••••••••••••";
              if (data.plaintextApiKey) {
                apiKeyInputEl.dataset.realKey = String(data.plaintextApiKey);
              } else {
                delete apiKeyInputEl.dataset.realKey;
              }
              if (data.llmModel) {
                const storedModel = String(data.llmModel);
                apiKeyInputEl.dataset.storedModel = storedModel;
                // Show it immediately if possible
                if (modelSelectEl) {
                  modelSelectEl.innerHTML = `<option value="${storedModel}">${storedModel}</option>`;
                  modelSelectEl.value = storedModel;
                }
              }
            }

            if (data.plaintextApiKey && fetchBtnEl) {
              fetchBtnEl.click();
            } else if (data.encryptedApiKey && modelStatusEl) {
              modelStatusEl.textContent =
                "Encrypted key found. Enter a new key or fetch models manually (requires decrypting).";
            }
          }
        }
      }

      function showMain() {
        setupView?.classList.add("hidden");
        mainView?.classList.remove("hidden");
      }

      settingsBtn?.addEventListener("click", showSetup);
      closeSettingsBtn?.addEventListener("click", showMain);

      // Check storage on load to auto-show setup if no key config exists
      document.addEventListener("DOMContentLoaded", async () => {
        try {
          if (typeof chrome !== "undefined" && chrome.storage) {
            const data = await chrome.storage.local.get([
              "plaintextApiKey",
              "encryptedApiKey",
            ]);

            if (!data.plaintextApiKey && !data.encryptedApiKey) {
              showSetup();
            }
          }
        } catch (e) {
          console.warn("Storage check failed on load", e);
        }
      });

      // ------------- Main Panel API -------------
      const openPantryBtn = document.getElementById("open-pantry-btn");
      const extractBtn = document.getElementById("extract-btn");
      const passwordContainer = document.getElementById("password-container");
      const confirmExtractBtn = document.getElementById("confirm-extract-btn");
      const passwordInput = document.getElementById(
        "popup-password"
      ) as HTMLInputElement;

      // Status UI Elements
      const statusViewport = document.getElementById("status-viewport");
      const statusScroller = document.getElementById("status-scroller");
      const errorContainer = document.getElementById("error-container");
      const errorExpandBtn = document.getElementById("error-expand-btn");
      const errorDetails = document.getElementById("error-details");

      function addStatusMessage(text: string, isError: boolean = false) {
        if (!statusViewport || !statusScroller) return;

        statusViewport.classList.remove("hidden");

        const active = statusScroller.querySelectorAll(".active");
        active.forEach((el) => el.classList.remove("active"));

        const p = document.createElement("p");
        p.className = "status-msg active";
        p.textContent = isError ? "Extraction failed" : text;
        if (isError) p.style.color = "#ef4444";

        statusScroller.appendChild(p);

        // Scroll to bottom
        setTimeout(() => {
          statusViewport.scrollTo({
            top: statusScroller.scrollHeight,
            behavior: "smooth",
          });
        }, 50);

        if (isError && errorContainer && errorDetails) {
          errorContainer.classList.remove("hidden");
          errorDetails.classList.add("hidden");
          if (errorExpandBtn) errorExpandBtn.textContent = "Show Details";
          errorDetails.textContent = text;
        } else if (!isError && errorContainer) {
          errorContainer.classList.add("hidden");
        }
      }

      errorExpandBtn?.addEventListener("click", () => {
        if (errorDetails) {
          errorDetails.classList.toggle("hidden");
          if (errorExpandBtn) {
            errorExpandBtn.textContent = errorDetails.classList.contains(
              "hidden"
            )
              ? "Show Details"
              : "Hide Details";
          }
        }
      });

      openPantryBtn?.addEventListener("click", () => {
        if (typeof chrome !== "undefined" && chrome.tabs) {
          chrome.tabs.create({ url: chrome.runtime.getURL("pantry.html") });
        } else {
          window.open("/pantry", "_blank");
        }
      });

      extractBtn?.addEventListener("click", async () => {
        if (extractBtn) {
          (extractBtn as HTMLButtonElement).disabled = true;
          extractBtn.textContent = "Loading...";
        }

        try {
          const storageResult: Record<string, any> =
            await chrome.storage.local.get([
              "plaintextApiKey",
              "llmModel",
              "llmProvider",
            ]);
          if (storageResult.plaintextApiKey) {
            const llmModel =
              storageResult.llmModel || "claude-3-5-sonnet-20241022";
            const llmProvider = storageResult.llmProvider || "anthropic";

            // Show status immediately since we bypassed the password button
            extractBtn?.classList.add("hidden");
            passwordContainer?.classList.remove("hidden");
            if (passwordInput) passwordInput.classList.add("hidden");
            if (confirmExtractBtn) confirmExtractBtn.classList.add("hidden");

            addStatusMessage("Starting extraction...");

            try {
              await executeExtraction(
                storageResult.plaintextApiKey as string,
                llmModel as string,
                llmProvider as string
              );
            } catch (err: any) {
              console.error("Extraction error", err);
              let msg = err.message || "Unknown error occurred";
              if (msg.length > 80) msg = msg.substring(0, 80) + "...";
              addStatusMessage(`Error: ${msg}`, true);
            }
            return;
          }
        } catch (e: any) {
          console.error("Storage error", e);
        }

        // Hide initial button and show password input
        extractBtn?.classList.add("hidden");
        passwordContainer?.classList.remove("hidden");
        passwordInput?.focus();
      });

      confirmExtractBtn?.addEventListener("click", async () => {
        const password = passwordInput?.value;
        if (!password) {
          addStatusMessage("Please enter your password.", true);
          return;
        }

        if (confirmExtractBtn) {
          (confirmExtractBtn as HTMLButtonElement).disabled = true;
          confirmExtractBtn.textContent = "Loading...";
        }

        addStatusMessage("Decrypting keys...");

        try {
          const storageResult: Record<string, any> =
            await chrome.storage.local.get([
              "encryptedApiKey",
              "llmModel",
              "llmProvider",
            ]);
          const encryptedApiKey = storageResult.encryptedApiKey;
          const llmModel =
            storageResult.llmModel || "claude-3-5-sonnet-20241022";
          const llmProvider = storageResult.llmProvider || "anthropic";

          if (!encryptedApiKey) {
            addStatusMessage("No API key found. Please run setup again.", true);
            if (confirmExtractBtn) {
              (confirmExtractBtn as HTMLButtonElement).disabled = false;
              confirmExtractBtn.textContent = "Confirm Extraction";
            }
            return;
          }

          const apiKey = await decryptData(encryptedApiKey, password);
          await executeExtraction(apiKey, llmModel, llmProvider);
        } catch (error: any) {
          console.error(error);
          let msg = error.message || "Unknown error";
          if (msg.length > 80) msg = msg.substring(0, 80) + "...";
          addStatusMessage(`Error: ${msg}`, true);
        } finally {
          if (
            confirmExtractBtn &&
            errorContainer &&
            !errorContainer.classList.contains("hidden")
          ) {
            // Only revert button if we didn't succeed, so they can try again if they want
            (confirmExtractBtn as HTMLButtonElement).disabled = false;
            confirmExtractBtn.textContent = "Confirm Extraction";
          }
        }
      });

      // Listen for background updates
      // Listen for background updates
      chrome.runtime.onMessage.addListener((message) => {
        if (message.type === "EXTRACTION_STATUS_UPDATE") {
          const { status, isError, isComplete } = message;
          addStatusMessage(status, isError);

          if (isError && confirmExtractBtn) {
            (confirmExtractBtn as HTMLButtonElement).disabled = false;
            confirmExtractBtn.textContent = "Confirm Extraction";
          }
          if (isComplete || isError) {
            // Let the user click it again if they want, or they can just close it
            if (extractBtn) {
              (extractBtn as HTMLButtonElement).disabled = false;
              extractBtn.textContent = "Extract & Add to Pantry";
            }
          }
        }
      });

      // Check for active extraction on load
      document.addEventListener("DOMContentLoaded", async () => {
        try {
          if (typeof chrome !== "undefined" && chrome.tabs) {
            const [tab] = await chrome.tabs.query({
              active: true,
              currentWindow: true,
            });
            if (tab && tab.id) {
              const response = await chrome.runtime.sendMessage({
                type: "GET_EXTRACTION_STATUS",
                url: tab.url,
              });
              if (response && response.isActive) {
                // Restore UI
                extractBtn?.classList.add("hidden");
                passwordContainer?.classList.remove("hidden");
                if (passwordInput) passwordInput.classList.add("hidden");
                if (confirmExtractBtn)
                  confirmExtractBtn.classList.add("hidden");

                addStatusMessage(
                  response.status || "Extracting in background..."
                );
              }
            }
          }
        } catch (e) {
          console.warn("Could not check extraction status", e);
        }

        // Also check if the URL is already saved
        try {
          if (
            typeof chrome !== "undefined" &&
            chrome.tabs &&
            chrome.storage &&
            chrome.storage.local
          ) {
            const [tab] = await chrome.tabs.query({
              active: true,
              currentWindow: true,
            });
            if (tab && tab.url) {
              const data = await chrome.storage.local.get("savedUrls");
              const urls: string[] = Array.isArray(data.savedUrls)
                ? data.savedUrls
                : [];
              // Standardize URL check by stripping trailing slash
              const normTabUrl = tab.url.replace(/\/$/, "");

              if (urls.some((u) => u.replace(/\/$/, "") === normTabUrl)) {
                if (extractBtn) {
                  extractBtn.textContent = "✓ Already Saved inside Pantry";
                  extractBtn.classList.remove("primary");
                  extractBtn.classList.add("outline");
                  // We can technically leave it clickable to just run again or we can disable it
                  // Let's just disable it and let them use the Open Pantry button
                  (extractBtn as HTMLButtonElement).disabled = true;
                }
              }
            }
          }
        } catch (e) {
          console.warn("Could not check saved status", e);
        }
      });

      async function executeExtraction(
        apiKey: string,
        llmModel: string,
        llmProvider: string
      ) {
        addStatusMessage("Initializing background extraction...");

        const [tab] = await chrome.tabs.query({
          active: true,
          currentWindow: true,
        });

        if (!tab || !tab.id) {
          addStatusMessage("Could not find active tab.", true);
          return;
        }

        console.log(
          `[Recipe AI] Triggering background extraction for tab: ${tab.url}`
        );

        // Send message to background script to take over
        chrome.runtime.sendMessage({
          type: "START_EXTRACTION",
          tabId: tab.id,
          url: tab.url,
          apiKey,
          llmModel,
          llmProvider,
        });

        // Background will start sending EXTRACTION_STATUS_UPDATE messages
      }

      // ------------- Setup logic -------------
      const finishBtn = document.getElementById("finish-setup-btn");
      const fetchModelsBtn = document.getElementById("fetch-models-btn");
      const providerSelect = document.getElementById(
        "provider-select"
      ) as HTMLSelectElement;
      const modelSelect = document.getElementById(
        "model-select"
      ) as HTMLSelectElement;
      const modelStatus = document.getElementById("model-status");
      const settingsApiKeyInput = document.getElementById(
        "api-key"
      ) as HTMLInputElement;
      const encryptionPasswordInput = document.getElementById(
        "encryption-password"
      ) as HTMLInputElement;

      fetchModelsBtn?.addEventListener("click", async () => {
        let apiKey = settingsApiKeyInput?.value;
        const provider = providerSelect.value;

        if (apiKey === "••••••••••••••••") {
          if (settingsApiKeyInput?.dataset.realKey) {
            apiKey = settingsApiKeyInput.dataset.realKey;
          } else {
            if (modelStatus)
              modelStatus.textContent =
                "Cannot auto-fetch with encrypted key. Please enter your API Key.";
            return;
          }
        }

        if (!apiKey) {
          if (modelStatus)
            modelStatus.textContent = "Please enter an API Key first.";
          return;
        }

        if (modelStatus)
          modelStatus.textContent = `Fetching available ${provider} models...`;
        console.log(`[Recipe AI] Fetching models from ${provider} API...`);
        if (fetchModelsBtn) {
          (fetchModelsBtn as HTMLButtonElement).disabled = true;
          (fetchModelsBtn as HTMLButtonElement).textContent = "Loading...";
        }

        modelSelect.innerHTML = "";
        modelSelect.disabled = true;

        try {
          let availableModels: {
            id: string;
            name: string;
            totalCost: number;
          }[] = [];

          if (provider === "anthropic") {
            const response = await fetch(
              "https://api.anthropic.com/v1/models",
              {
                method: "GET",
                headers: {
                  "x-api-key": apiKey,
                  "anthropic-version": "2023-06-01",
                  "anthropic-dangerous-direct-browser-access": "true",
                },
              }
            );
            if (!response.ok) throw new Error(await response.text());
            const data = await response.json();
            availableModels = data.data.map((m: any) => ({
              id: m.id,
              name: m.display_name || m.id,
              totalCost: 0,
            }));
          } else if (provider === "openrouter") {
            const response = await fetch(
              "https://openrouter.ai/api/v1/models",
              {
                headers: { Authorization: `Bearer ${apiKey}` },
              }
            );
            if (!response.ok) throw new Error(await response.text());
            const data = await response.json();

            const weakKeywords = [
              "tiny",
              "-1b",
              "-3b",
              "gpt-2",
              "gpt-j",
              "rwkv",
              "gemma-2b",
              "llama-3.2-1b",
              "qwen-1.5b",
              "gemma-2-2b",
              "yi-6b",
              "-8b",
            ];
            let filteredOpenRouter = data.data.filter((m: any) => {
              const idLower = m.id.toLowerCase();
              return (
                !weakKeywords.some((keyword) => idLower.includes(keyword)) &&
                (m.context_length || 0) >= 8000
              );
            });

            availableModels = filteredOpenRouter.map((m: any) => {
              const inPrice = Number(m.pricing?.prompt) * 1000000 || 0;
              const outPrice = Number(m.pricing?.completion) * 1000000 || 0;
              let name = m.name || m.id;
              if (inPrice > 0 || outPrice > 0)
                name += ` ($${inPrice.toFixed(2)}/$${outPrice.toFixed(
                  2
                )} per 1M)`;
              else name += ` (Free)`;
              return { id: m.id, name, totalCost: inPrice + outPrice };
            });
            availableModels.sort((a, b) => a.totalCost - b.totalCost);
          }

          if (availableModels.length === 0) {
            if (modelStatus)
              modelStatus.textContent = "No models found for this key.";
            return;
          }

          availableModels.forEach((m) => {
            const option = document.createElement("option");
            option.value = m.id;
            option.textContent = m.name;
            modelSelect.appendChild(option);
          });

          modelSelect.disabled = false;

          if (settingsApiKeyInput?.dataset.storedModel) {
            const storedModel = settingsApiKeyInput.dataset.storedModel;
            if (availableModels.some((m) => m.id === storedModel)) {
              modelSelect.value = storedModel;
            } else {
              // Add it just in case it's a custom or older model
              const option = document.createElement("option");
              option.value = storedModel;
              option.textContent = `${storedModel} (Stored)`;
              modelSelect.appendChild(option);
              modelSelect.value = storedModel;
            }
          }

          if (modelStatus)
            modelStatus.textContent = "Models loaded successfully!";
          if (fetchModelsBtn) {
            (fetchModelsBtn as HTMLButtonElement).disabled = false;
            fetchModelsBtn.textContent = "Fetch Models";
          }
        } catch (error: any) {
          console.error("Failed to fetch models:", error);
          if (modelStatus) modelStatus.textContent = "Failed to fetch models.";
          const option = document.createElement("option");
          option.value = "";
          option.textContent = "Error fetching models";
          modelSelect.appendChild(option);
          if (fetchModelsBtn) {
            (fetchModelsBtn as HTMLButtonElement).disabled = false;
            fetchModelsBtn.textContent = "Fetch Models";
          }
        }
      });

      finishBtn?.addEventListener("click", async () => {
        const password = encryptionPasswordInput.value;
        const inputKey = settingsApiKeyInput.value;
        let apiKey = inputKey;

        if (inputKey === "••••••••••••••••") {
          if (settingsApiKeyInput.dataset.realKey) {
            apiKey = settingsApiKeyInput.dataset.realKey;
          } else {
            apiKey = ""; // It's an encrypted key, we just won't update it
          }
        }

        const modelSelection = modelSelect.value;
        const providerSelection = providerSelect.value;

        if (!inputKey) {
          if (modelStatus) {
            modelStatus.innerHTML =
              "<span style='color:red'>Please enter an API Key.</span>";
          }
          return;
        }

        if (
          typeof chrome !== "undefined" &&
          chrome.storage &&
          chrome.storage.local
        ) {
          const storageData: Record<string, any> = {
            setupComplete: true,
            llmModel: modelSelection,
            llmProvider: providerSelection,
          };

          if (apiKey) {
            if (password) {
              try {
                const encryptedApiKey = await encryptData(apiKey, password);
                storageData.encryptedApiKey = encryptedApiKey;
                await chrome.storage.local.remove(["plaintextApiKey"]);
              } catch (err) {
                console.error("Encryption failed:", err);
                if (modelStatus) modelStatus.textContent = "Encryption failed.";
                return;
              }
            } else {
              storageData.plaintextApiKey = apiKey;
              await chrome.storage.local.remove(["encryptedApiKey"]);
            }
          } else if (inputKey === "••••••••••••••••") {
            // we are keeping the existing key (presumably encrypted without password provided just now)
            // so we don't modify plaintextApiKey or encryptedApiKey in storageData
          }

          await chrome.storage.local.set(storageData);
          showMain(); // Return to main UI
        }
      });
    </script>
  </body>
</html>
