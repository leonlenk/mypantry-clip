---
import "../styles/global.scss";
import "../styles/pantry.scss";
import TopBar from "../components/pantry/TopBar.astro";
import RecipeGrid from "../components/pantry/RecipeGrid.astro";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Recipe AI - Pantry Dashboard</title>
  </head>
  <body>
    <div class="pantry-layout">
      <main class="content">
        <TopBar />
        <RecipeGrid />
      </main>
    </div>

    <script>
      import {
        getAllRecipes,
        deleteRecipe,
        searchRecipes,
        saveRecipeLocally,
      } from "../utils/db";
      import type { Recipe } from "../types/recipe";

      declare const chrome: any;

      const grid = document.getElementById("recipe-grid");
      const emptyState = document.getElementById("empty-state");
      const searchInput = document.getElementById(
        "semantic-search"
      ) as HTMLInputElement;
      const searchBtn = document.getElementById(
        "search-btn"
      ) as HTMLButtonElement;
      const recipeCountEl = document.getElementById("recipe-count");
      const filterLinks = document.querySelectorAll(".filter-btn");
      const tagFilterSelect = document.getElementById(
        "tag-filter"
      ) as HTMLSelectElement;

      let currentFilter = "all";
      let currentTagFilter = "";

      document.addEventListener("DOMContentLoaded", async () => {
        // Redirect to setup if not configured
        if (
          typeof chrome !== "undefined" &&
          chrome.storage &&
          chrome.storage.local
        ) {
          const { setupComplete } = await chrome.storage.local.get([
            "setupComplete",
          ]);
          if (!setupComplete) {
            window.location.href = "setup.html";
            return;
          }
        }

        filterLinks.forEach((link) => {
          link.addEventListener("click", async (e) => {
            e.preventDefault();
            filterLinks.forEach((l) => l.classList.remove("active"));
            (e.currentTarget as HTMLElement).classList.add("active");
            currentFilter =
              (e.currentTarget as HTMLElement).dataset.filter || "all";
            await loadRecipes();
          });
        });

        tagFilterSelect?.addEventListener("change", async (e) => {
          currentTagFilter = (e.target as HTMLSelectElement).value;
          await loadRecipes();
        });

        await loadRecipes();
      });

      function populateTags(allRecipes: Recipe[]) {
        if (!tagFilterSelect) return;
        const allTags = new Set<string>();
        allRecipes.forEach((r) => {
          if (r.tags) {
            r.tags.forEach((t) => allTags.add(t));
          }
        });

        const currentVal = tagFilterSelect.value;

        tagFilterSelect.innerHTML = '<option value="">All Tags</option>';
        Array.from(allTags)
          .sort()
          .forEach((tag) => {
            const option = document.createElement("option");
            option.value = tag;
            option.textContent = tag;
            tagFilterSelect.appendChild(option);
          });

        if (currentVal && allTags.has(currentVal)) {
          tagFilterSelect.value = currentVal;
        } else {
          currentTagFilter = "";
        }
      }

      async function loadRecipes() {
        let recipes = await getAllRecipes();

        // Populate tags before applying any filters so all tags are available
        populateTags(recipes);

        if (currentFilter === "recent") {
          recipes = recipes.reverse();
        } else if (currentFilter === "favorites") {
          recipes = recipes.filter((r) => r.isFavorite);
        }

        if (currentTagFilter) {
          recipes = recipes.filter(
            (r) => r.tags && r.tags.includes(currentTagFilter)
          );
        }

        if (recipeCountEl)
          recipeCountEl.textContent = `${recipes.length} recipe${
            recipes.length !== 1 ? "s" : ""
          }`;
        renderRecipes(recipes);
      }

      function renderRecipes(recipes: Recipe[]) {
        if (!grid || !emptyState) return;
        grid.innerHTML = "";

        if (recipes.length === 0) {
          grid.classList.add("hidden");
          emptyState.classList.remove("hidden");
          return;
        }

        grid.classList.remove("hidden");
        emptyState.classList.add("hidden");

        recipes.forEach((recipe: Recipe, index: number) => {
          const card = document.createElement("div");
          card.className = "card recipe-card";
          card.style.animationDelay = `${index * 0.05}s`;

          const tagsHtml = recipe.tags
            ? recipe.tags
                .map((tag) => `<span class="tag">${tag}</span>`)
                .join("")
            : "";

          const metaHtml = [
            recipe.totalTimeMinutes ? `⏱ ${recipe.totalTimeMinutes}m` : null,
            recipe.servings ? `🍽 ${recipe.servings} servings` : null,
            recipe.yield ? `📦 ${recipe.yield}` : null,
          ]
            .filter(Boolean)
            .join(" &nbsp;·&nbsp; ");

          const description = (recipe.description || "").slice(0, 140);

          card.innerHTML = `
          <div class="card-header">
            <h3>${recipe.title}</h3>
            <div class="card-actions">
              <button class="favorite-btn" data-id="${
                recipe.id
              }" title="Toggle favorite">
                ${recipe.isFavorite ? "★" : "☆"}
              </button>
              <button class="delete-btn" data-id="${
                recipe.id
              }" title="Delete recipe">✕</button>
            </div>
          </div>
          ${metaHtml ? `<p class="meta">${metaHtml}</p>` : ""}
          <p class="desc">${description}${
            (recipe.description || "").length > 140 ? "..." : ""
          }</p>
          <div class="tags">${tagsHtml}</div>
          <div class="card-footer">
            ${
              recipe.url
                ? `<a href="${recipe.url}" target="_blank" class="view-btn">View Source →</a>`
                : "<span></span>"
            }
          </div>
        `;

          card.addEventListener("click", () => {
            window.location.href = `recipe.html?id=${recipe.id}`;
          });

          card.querySelector(".view-btn")?.addEventListener("click", (e) => {
            e.stopPropagation();
          });

          card
            .querySelector(".favorite-btn")
            ?.addEventListener("click", async (e) => {
              e.stopPropagation();
              recipe.isFavorite = !recipe.isFavorite;

              // Immediately update UI before db op
              (e.currentTarget as HTMLButtonElement).textContent =
                recipe.isFavorite ? "★" : "☆";

              await saveRecipeLocally(recipe);
              if (currentFilter === "favorites" && !recipe.isFavorite) {
                card.remove();
                const remaining = grid.querySelectorAll(".recipe-card").length;
                if (recipeCountEl)
                  recipeCountEl.textContent = `${remaining} recipe${
                    remaining !== 1 ? "s" : ""
                  }`;
                if (remaining === 0) {
                  grid.classList.add("hidden");
                  emptyState.classList.remove("hidden");
                }
              }
            });

          card
            .querySelector(".delete-btn")
            ?.addEventListener("click", async (e) => {
              e.stopPropagation();
              const id = (e.currentTarget as HTMLButtonElement).dataset.id!;
              await deleteRecipe(id);
              card.remove();
              const remaining = grid.querySelectorAll(".recipe-card").length;
              if (recipeCountEl)
                recipeCountEl.textContent = `${remaining} recipe${
                  remaining !== 1 ? "s" : ""
                }`;
              if (remaining === 0) {
                grid.classList.add("hidden");
                emptyState.classList.remove("hidden");
              }
            });

          grid.appendChild(card);
        });
      }

      async function handleSearch() {
        const query = searchInput.value.trim();
        if (!query) {
          await loadRecipes();
          return;
        }

        searchBtn.disabled = true;
        searchBtn.textContent = "Searching...";

        try {
          // Ask the background script to generate an embedding using the offscreen document
          const result: {
            success: boolean;
            embedding?: number[];
            error?: string;
          } = await chrome.runtime.sendMessage({
            type: "GENERATE_EMBEDDING",
            text: query,
          });

          if (result.success && result.embedding) {
            const matches = await searchRecipes(result.embedding, 20);
            renderRecipes(matches);
            if (recipeCountEl)
              recipeCountEl.textContent = `${matches.length} result${
                matches.length !== 1 ? "s" : ""
              } for "${query}"`;
          } else {
            console.error("Search embedding failed:", result.error);
            // Fall back to simple text search across title and tags
            const all = await getAllRecipes();
            const lower = query.toLowerCase();
            const filtered = all.filter(
              (r) =>
                r.title?.toLowerCase().includes(lower) ||
                r.tags?.some((t) => t.toLowerCase().includes(lower))
            );
            renderRecipes(filtered);
          }
        } catch (err) {
          console.error("Search error:", err);
        } finally {
          searchBtn.disabled = false;
          searchBtn.textContent = "Search";
        }
      }

      searchBtn?.addEventListener("click", handleSearch);

      searchInput?.addEventListener("keydown", (e: KeyboardEvent) => {
        if (e.key === "Enter") handleSearch();
      });

      // Reset to all recipes when search is cleared
      searchInput?.addEventListener("input", async () => {
        if (searchInput.value === "") await loadRecipes();
      });
    </script>
  </body>
</html>
