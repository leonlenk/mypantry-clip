# Extension build-time environment variables (loaded by Astro/Vite)
# These values are inlined at build time, NOT exposed as API secrets at runtime.
# Supabase public project URL (safe to expose in the extension bundle)
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Backend API base URL — stored in chrome.storage.local at login so the esbuild
# service worker bundle can read it without import.meta.env.
PUBLIC_API_URL=https://your-mypantry-api.com
