---
// offscreen.astro
// This Astro page generates the offscreen.html entry for the Chrome Offscreen API.
// It is a minimal shell that only loads the embedder script as a module.
// Chrome spawns this as a hidden document to safely run Transformers.js WASM
// outside the Service Worker's 30-second timeout limit.
---

<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8" />
        <title>MyPantry Offscreen</title>
    </head>
    <body>
        <script>
            import { pipeline, env } from "@huggingface/transformers";

            // Disable remote models and browser cache — load purely from packaged local files.
            // @ts-ignore
            env.allowLocalModels = true;
            // @ts-ignore
            env.allowRemoteModels = false;
            // @ts-ignore
            env.useBrowserCache = false;
            // Use the bundled files path (relative to the extension root)
            // @ts-ignore
            env.localModelPath = chrome.runtime.getURL("models");

            // Override the ORT WASM/JSEP base path. By default transformers.web.js sets
            // this to the CDN (cdn.jsdelivr.net) so it can find ort-wasm-simd-threaded.jsep.mjs
            // and .wasm at runtime. We copy those files into public/ort/ via download-model.mjs
            // so they are bundled in the extension and served from our own origin.
            // @ts-ignore
            env.backends.onnx.wasm.wasmPaths = chrome.runtime.getURL("ort/");

            let extractor: any = null;

            async function resolveDevice(): Promise<string> {
                try {
                    if (navigator.gpu) {
                        const adapter = await navigator.gpu.requestAdapter();
                        if (adapter) return "webgpu";
                    }
                } catch (_) {}
                console.warn("[MyPantry Offscreen] WebGPU unavailable, falling back to WASM.");
                return "wasm";
            }

            async function getExtractor() {
                if (!extractor) {
                    // snowflake-arctic-embed-s int8 (model_quantized.onnx, ~34MB, 384-dim).
                    // Uses WebGPU when available for best performance; falls back to WASM
                    // (CPU) on machines without a usable GPU adapter.
                    const device = await resolveDevice();
                    extractor = await pipeline(
                        "feature-extraction",
                        "Snowflake/snowflake-arctic-embed-s",
                        {
                            dtype: "q8",
                            device,
                        }
                    );
                }
                return extractor;
            }

            // Listen for embedding requests from the background service worker
            chrome.runtime.onMessage.addListener(
                (message, _sender, sendResponse) => {
                    if (
                        message.type !== "GENERATE_EMBEDDING" ||
                        message.target !== "offscreen"
                    )
                        return;

                    const text: string = message.text;

                    // Return true to keep chrome message channel open for async response
                    (async () => {
                        try {
                            console.log(
                                "[MyPantry Offscreen] Generating embedding for text length:",
                                text.length
                            );
                            const pipe = await getExtractor();
                            const output = await (pipe as any)(text, {
                                pooling: "mean",
                                normalize: true,
                            });
                            // Serialize the Float32Array tensor output to a plain JS number array
                            const embedding: number[] = Array.from(
                                output.data as Float32Array
                            );
                            console.log(
                                `[MyPantry Offscreen] Done. Embedding dimension: ${embedding.length}`
                            );
                            sendResponse({ success: true, embedding });
                        } catch (error: any) {
                            console.error(
                                "[MyPantry Offscreen] Embedding failed:",
                                error
                            );
                            sendResponse({
                                success: false,
                                error: error.message,
                            });
                        }
                    })();

                    return true; // Signal async response
                }
            );
        </script>
    </body>
</html>
