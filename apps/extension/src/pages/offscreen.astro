---
// offscreen.astro
// This Astro page generates the offscreen.html entry for the Chrome Offscreen API.
// It is a minimal shell that only loads the embedder script as a module.
// Chrome spawns this as a hidden document to safely run Transformers.js WASM
// outside the Service Worker's 30-second timeout limit.
---

<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8" />
        <title>MyPantry Offscreen</title>
    </head>
    <body>
        <script>
            import { pipeline, env } from "@huggingface/transformers";

            // Allow Transformers.js to cache the model in the browser Cache API.
            // Do NOT load local models (no bundling) - fetch from HuggingFace on first use.
            // @ts-ignore
            env.allowLocalModels = false;
            // @ts-ignore
            env.useBrowserCache = true;

            let extractor: any = null;

            async function getExtractor() {
                if (!extractor) {
                    // snowflake-arctic-embed-s int8 (model_quantized.onnx, ~34MB, 384-dim).
                    // Using dtype:"q8" targets the 8-bit quantized ONNX file — a good balance
                    // of size (~34MB) and quality. Running in the offscreen document avoids
                    // the Service Worker 30-second timeout limit.
                    extractor = await pipeline(
                        "feature-extraction",
                        "Snowflake/snowflake-arctic-embed-s",
                        {
                            dtype: "q8",
                            device: "webgpu",
                            progress_callback: (info) => {
                                chrome.runtime
                                    .sendMessage({
                                        type: "DOWNLOAD_PROGRESS",
                                        ...info,
                                    })
                                    .catch(() => {});
                            },
                        }
                    );
                }
                return extractor;
            }

            // Listen for embedding requests from the background service worker
            chrome.runtime.onMessage.addListener(
                (message, _sender, sendResponse) => {
                    if (
                        message.type === "INIT_MODEL_DOWNLOAD" &&
                        message.target === "offscreen"
                    ) {
                        getExtractor()
                            .then(() => sendResponse({ success: true }))
                            .catch((error) =>
                                sendResponse({
                                    success: false,
                                    error: error.message,
                                })
                            );
                        return true;
                    }

                    if (
                        message.type === "CHECK_MODEL_CACHED" &&
                        message.target === "offscreen"
                    ) {
                        // Check the browser Cache API for the model's quantized ONNX file.
                        // Transformers.js stores files under a cache named "transformers-cache".
                        // If the key model file is present, the model is fully downloaded.
                        (async () => {
                            try {
                                // If the pipeline was already initialised in this session, it's definitely ready.
                                if (extractor) {
                                    sendResponse({ cached: true });
                                    return;
                                }
                                const cache = await caches.open(
                                    "transformers-cache"
                                );
                                const keys = await cache.keys();
                                // Look for the quantized ONNX weights file for our model
                                const modelFile = keys.find(
                                    (req) =>
                                        req.url.includes(
                                            "snowflake-arctic-embed-s"
                                        ) &&
                                        req.url.includes("model_quantized.onnx")
                                );
                                sendResponse({ cached: !!modelFile });
                            } catch (err) {
                                // If the Cache API is unavailable, assume not cached
                                sendResponse({ cached: false });
                            }
                        })();
                        return true;
                    }

                    if (
                        message.type !== "GENERATE_EMBEDDING" ||
                        message.target !== "offscreen"
                    )
                        return;

                    const text: string = message.text;

                    // Return true to keep chrome message channel open for async response
                    (async () => {
                        try {
                            console.log(
                                "[MyPantry Offscreen] Generating embedding for text length:",
                                text.length
                            );
                            const pipe = await getExtractor();
                            const output = await (pipe as any)(text, {
                                pooling: "mean",
                                normalize: true,
                            });
                            // Serialize the Float32Array tensor output to a plain JS number array
                            const embedding: number[] = Array.from(
                                output.data as Float32Array
                            );
                            console.log(
                                `[MyPantry Offscreen] Done. Embedding dimension: ${embedding.length}`
                            );
                            sendResponse({ success: true, embedding });
                        } catch (error: any) {
                            console.error(
                                "[MyPantry Offscreen] Embedding failed:",
                                error
                            );
                            sendResponse({
                                success: false,
                                error: error.message,
                            });
                        }
                    })();

                    return true; // Signal async response
                }
            );
        </script>
    </body>
</html>
