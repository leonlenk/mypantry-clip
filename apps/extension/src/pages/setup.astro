---
import "../styles/global.scss";
import ByokForm from "../components/shared/ByokForm.astro";
import feather from "feather-icons";

const downloadIcon =
    (feather.icons["download"] || feather.icons["help-circle"])?.toSvg({
        width: 48,
        height: 48,
        color: "var(--color-accent)",
    }) || "";
const coffeeIcon =
    (feather.icons["coffee"] || feather.icons["help-circle"])?.toSvg({
        width: 48,
        height: 48,
        color: "var(--color-accent)",
    }) || "";
const keyIcon =
    (feather.icons["key"] || feather.icons["help-circle"])?.toSvg({
        width: 18,
        height: 18,
        color: "var(--color-text-muted)",
    }) || "";
const arrowLeftIcon =
    (feather.icons["arrow-left"] || feather.icons["help-circle"])?.toSvg({
        width: 16,
        height: 16,
    }) || "";
const cloudIcon =
    (feather.icons["cloud"] || feather.icons["help-circle"])?.toSvg({
        width: 18,
        height: 18,
        color: "var(--color-text-muted)",
    }) || "";
const userIcon =
    (feather.icons["user"] || feather.icons["help-circle"])?.toSvg({
        width: 18,
        height: 18,
        color: "var(--color-text-muted)",
    }) || "";
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>MyPantry Clip - Setup</title>
        <style>
            body {
                display: flex;
                justify-content: center;
                align-items: center;
                min-height: 100vh;
                background-color: var(--color-surface);
            }
            .setup-card {
                max-width: 480px;
                width: 100%;
                text-align: center;
                padding: var(--spacing-xl);
            }
            .brand-title {
                font-family: var(--font-serif);
                color: var(--color-primary);
                font-size: 2.5rem;
                margin-bottom: var(--spacing-xs);
                letter-spacing: -0.02em;
            }
            .brand-subtitle {
                color: var(--color-text-muted);
                font-size: 1.1rem;
                margin-bottom: var(--spacing-xl);
            }

            .view-state {
                display: none;
                animation: fadeIn 0.3s ease-in-out;
            }

            .view-state.active {
                display: block;
            }

            @keyframes fadeIn {
                from {
                    opacity: 0;
                    transform: translateY(5px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            /* Inline spinner shown while the OAuth choice card is loading */
            .btn-spinner {
                display: inline-block;
                width: 14px;
                height: 14px;
                border: 2px solid var(--color-border);
                border-top-color: var(--color-text-muted);
                border-radius: 50%;
                animation: btn-spin 0.7s linear infinite;
                flex-shrink: 0;
            }

            @keyframes btn-spin {
                to {
                    transform: rotate(360deg);
                }
            }

            /* Progress Bar Styles */
            .progress-container {
                width: 100%;
                height: 8px;
                background-color: var(--color-border);
                border-radius: var(--radius-pill);
                overflow: hidden;
                margin: var(--spacing-md) 0;
            }

            .progress-fill {
                height: 100%;
                background-color: var(--color-accent);
                width: 0%;
                transition: width 0.2s ease-out;
            }

            .step-label {
                font-size: 0.75rem;
                font-weight: 600;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                color: var(--color-text-muted);
                margin-bottom: var(--spacing-sm);
            }

            .step-heading {
                font-size: 1.15rem;
                font-weight: 600;
                color: var(--color-primary);
                margin-bottom: var(--spacing-lg);
            }

            .choice-card {
                border: 1px solid var(--color-border);
                border-radius: var(--radius-md);
                padding: 14px 16px;
                margin-bottom: var(--spacing-sm);
                text-align: left;
                cursor: pointer;
                background: var(--color-bg);
                transition: border-color 0.15s, background 0.15s, box-shadow 0.15s;
                width: 100%;
                display: flex;
                align-items: center;
                gap: 14px;
            }

            .choice-card:hover {
                border-color: var(--color-accent);
                background: var(--color-surface);
                box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
            }

            .choice-card:disabled {
                opacity: 0.6;
                cursor: not-allowed;
                border-color: var(--color-border);
                box-shadow: none;
            }

            .choice-card-icon {
                flex-shrink: 0;
                width: 36px;
                height: 36px;
                border-radius: var(--radius-sm);
                background: var(--color-surface);
                border: 1px solid var(--color-border);
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .choice-card-body {
                flex: 1;
                min-width: 0;
                text-align: left;
            }

            .choice-card-title {
                font-weight: 600;
                font-size: 0.95rem;
                color: var(--color-primary);
                margin-bottom: 2px;
                display: flex;
                align-items: center;
                gap: 6px;
            }

            .choice-card-desc {
                font-size: 0.8rem;
                color: var(--color-text-muted);
                margin: 0;
                line-height: 1.4;
            }

            #step-byok {
                position: relative;
            }

            .btn-back {
                position: absolute;
                top: 0;
                left: 0;
                display: inline-flex;
                align-items: center;
                gap: 6px;
                background: none;
                border: none;
                padding: 0;
                font-size: 0.85rem;
                color: var(--color-text-muted);
                cursor: pointer;
                transition: color 0.15s;
            }

            .btn-back:hover {
                color: var(--color-primary);
            }

            .badge {
                font-size: 0.65rem;
                font-weight: 700;
                letter-spacing: 0.04em;
                text-transform: uppercase;
                padding: 2px 6px;
                border-radius: var(--radius-pill);
                background: var(--color-accent);
                color: white;
            }
        </style>
    </head>
    <body>
        <main class="card setup-card">
            <h1 class="brand-title">MyPantry Clip</h1>
            <p class="brand-subtitle">Your intelligent recipe vault</p>

            <!-- STEP 1: IDENTITY CHOICE -->
            <section id="step-identity" class="view-state active">
                <p class="step-label">Step 1 of 2</p>
                <p class="step-heading">How do you want to sign in?</p>

                <button id="btn-oauth-google" class="choice-card">
                    <div class="choice-card-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24">
                            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"></path>
                            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"></path>
                            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"></path>
                            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"></path>
                        </svg>
                    </div>
                    <div class="choice-card-body">
                        <div class="choice-card-title">
                            Sign in with Google
                            <span class="badge">Recommended</span>
                        </div>
                        <p class="choice-card-desc">Sync recipes across devices. Free cloud backup included.</p>
                    </div>
                </button>

                <button id="btn-continue-anonymous" class="choice-card">
                    <div class="choice-card-icon">
                        <span set:html={userIcon}></span>
                    </div>
                    <div class="choice-card-body">
                        <div class="choice-card-title">Continue Anonymously</div>
                        <p class="choice-card-desc">Use your own API key. No account required, fully local.</p>
                    </div>
                </button>
            </section>

            <!-- STEP 2: API CHOICE (Google users only) -->
            <section id="step-api-choice" class="view-state">
                <p class="step-label">Step 2 of 2</p>
                <p class="step-heading">How should recipes be extracted?</p>

                <button id="btn-choose-cloud" class="choice-card">
                    <div class="choice-card-icon">
                        <span set:html={cloudIcon}></span>
                    </div>
                    <div class="choice-card-body">
                        <div class="choice-card-title">
                            MyPantry Clip Cloud API
                            <span class="badge">Recommended</span>
                        </div>
                        <p class="choice-card-desc">Powered by Gemini via our servers. No API key needed.</p>
                    </div>
                </button>

                <button id="btn-choose-byok" class="choice-card">
                    <div class="choice-card-icon">
                        <span set:html={keyIcon}></span>
                    </div>
                    <div class="choice-card-body">
                        <div class="choice-card-title">Bring Your Own Key</div>
                        <p class="choice-card-desc">Use your own key from Google, Anthropic, OpenAI, or OpenRouter.</p>
                    </div>
                </button>
            </section>

            <!-- STEP 3: BYOK FORM (anonymous or Google+BYOK) -->
            <section id="step-byok" class="view-state">
                <button id="btn-back-byok" class="btn-back">
                    <span set:html={arrowLeftIcon}></span> Back
                </button>
                <p class="step-label">API Key Setup</p>
                <p class="step-heading" style="margin-bottom: var(--spacing-md);">Configure your API key</p>
                <ByokForm idPrefix="setup-byok-" />
            </section>

            <!-- STEP 4: POPULATING PANTRY (cold boot sync, Google OAuth + Cloud only) -->
            <section id="step-syncing" class="view-state">
                <span
                    set:html={downloadIcon}
                    style="display:block;margin-bottom:1rem;"></span>
                <h2>Populating your Pantry...</h2>
                <p class="text-meta" style="margin-bottom: 2rem;">
                    Pulling your recipes from the cloud. Just a moment!
                </p>
                <div class="progress-container">
                    <div id="sync-bar-fill" class="progress-fill"></div>
                </div>
                <p id="sync-text" style="font-size: 0.9rem; font-weight: 500;">
                    Starting sync...
                </p>
            </section>

            <!-- STEP 5: READY -->
            <section id="step-ready" class="view-state">
                <span
                    set:html={coffeeIcon}
                    style="display:block;margin-bottom:1rem;"></span>

                <h2>You're all set!</h2>
                <p>
                    MyPantry Clip is ready. You can now close this tab, pin the
                    extension to your toolbar, and start saving recipes!
                </p>
                <button id="btn-close-tab" class="btn outline mt"
                    >Close Tab</button
                >
            </section>
        </main>

        <script src="../utils/setup.ts"></script>
    </body>
</html>
