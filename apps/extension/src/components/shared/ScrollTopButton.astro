---
import feather from "feather-icons";
// Large stroke makes the ^ clearly readable without any surrounding box
const chevronUp =
    feather.icons["chevron-up"]?.toSvg({
        width: 28,
        height: 28,
        "stroke-width": 3,
    }) || "";
---

<button
    id="scroll-top-btn"
    class="scroll-top-btn"
    title="Back to top"
    aria-label="Scroll to top"
    set:html={chevronUp}></button>

<style>
    .scroll-top-btn {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        width: 36px;
        height: 36px;
        background: none;
        border: none;
        padding: 0;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-text-muted);
        /* drop-shadow makes the icon pop on any bg without a bounding box */
        filter: drop-shadow(0 1px 3px rgba(0, 0, 0, 0.25));
        opacity: 0;
        pointer-events: none;
        transform: translateY(8px);
        transition: opacity 0.25s ease, transform 0.25s ease, color 0.2s ease;
        z-index: 100;

        &.visible {
            opacity: 1;
            pointer-events: auto;
            transform: translateY(0);
        }

        &:hover {
            color: var(--color-accent);
            filter: drop-shadow(0 2px 6px rgba(0, 0, 0, 0.3));
        }

        :global(svg) {
            display: block;
        }
    }
</style>

<script>
    const btn = document.getElementById(
        "scroll-top-btn"
    ) as HTMLButtonElement | null;
    if (!btn) throw new Error("scroll-top-btn not found");

    // The pantry page scrolls on .content; the recipe page scrolls on body/window.
    // We listen to both so a single component works everywhere.
    const scrollTarget =
        document.querySelector<HTMLElement>(".content") ??
        document.documentElement;

    function onScroll() {
        const scrolled =
            scrollTarget.scrollTop ||
            document.documentElement.scrollTop ||
            window.scrollY;
        btn!.classList.toggle("visible", scrolled > 300);
    }

    // Attach to both the container and the window to cover all layouts
    scrollTarget.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("scroll", onScroll, { passive: true });

    btn.addEventListener("click", () => {
        scrollTarget.scrollTo({ top: 0, behavior: "smooth" });
        window.scrollTo({ top: 0, behavior: "smooth" });
    });
</script>
