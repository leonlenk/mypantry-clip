---
import feather from "feather-icons";
const searchIcon =
    feather.icons["search"]?.toSvg({ width: 18, height: 18 }) || "";
const clearIcon = feather.icons["x"]?.toSvg({ width: 18, height: 18 }) || "";
---

<div class="search-bar-container">
    <div class="search-wrap">
        <div class="search-input-container">
            <span class="search-icon" set:html={searchIcon}></span>
            <div id="search-badges" class="search-badges"></div>
            <input
                type="text"
                id="semantic-search"
                placeholder="Search by tags, ingredients, or describe a craving..."
                autocomplete="off"
            />
            <button id="clear-search" class="clear-btn" title="Clear search">
                <span set:html={clearIcon}></span>
            </button>
            <div id="search-suggestions" class="search-suggestions hidden">
            </div>
        </div>
        <button class="primary" id="search-btn">Search</button>
    </div>
    <div class="count-wrap">
        <span id="recipe-count" class="recipe-count"></span>
    </div>
</div>
