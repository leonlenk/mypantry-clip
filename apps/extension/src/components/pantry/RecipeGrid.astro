---
import feather from "feather-icons";
// book-open is a good metaphor for an empty recipe collection
const emptyIcon = feather.icons["book-open"].toSvg({ width: 48, height: 48 });
---

<section class="recipe-grid" id="recipe-grid">
    <!-- Recipes injected here via JS -->
</section>

<!-- Empty State -->
<div id="empty-state" class="empty-state hidden">
    <div class="empty-icon" set:html={emptyIcon}></div>
    <h3>Your pantry is empty</h3>
    <p>Extract recipes from the web using the Pantry Clip extension panel.</p>
</div>
