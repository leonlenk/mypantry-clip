---
import feather from "feather-icons";
// book-open is a good metaphor for an empty recipe collection
const emptyIcon = feather.icons["book-open"].toSvg({ width: 48, height: 48 });
---

<section class="recipe-grid" id="recipe-grid">
    <!-- Recipes injected here via JS -->
</section>

<!-- Empty State -->
<div id="empty-state" class="empty-state hidden">
    <div class="empty-icon" set:html={emptyIcon}></div>
    <h3>Your pantry is empty</h3>
    <p>Extract recipes from the web using the Pantry Clip extension panel.</p>
</div>

<!-- Toast notification -->
<div id="pantry-toast" class="pantry-toast hidden" role="status" aria-live="polite"></div>

<!-- Share links result modal (shown after links are generated) -->
<div id="share-links-overlay" class="delete-confirm-overlay hidden" role="dialog" aria-modal="true" aria-labelledby="share-links-title">
    <div class="delete-confirm-modal">
        <h3 id="share-links-title">Recipe shared!</h3>
        <p class="delete-confirm-subtitle">Anyone with the link can view this recipe. Links expire in 30 days.</p>
        <div id="share-links-list" class="share-links-list"></div>
        <div class="delete-confirm-actions">
            <button id="share-links-close" class="delete-btn secondary">Done</button>
        </div>
    </div>
</div>

<!-- Share confirmation modal -->
<div id="share-confirm-overlay" class="delete-confirm-overlay hidden" role="dialog" aria-modal="true" aria-labelledby="share-confirm-title">
    <div class="delete-confirm-modal">
        <h3 id="share-confirm-title">Share recipes?</h3>
        <p class="delete-confirm-subtitle">Each recipe below gets its own shareable link. Personal tags are removed before sharing.</p>
        <ul id="share-confirm-list" class="delete-confirm-list"></ul>
        <div class="delete-confirm-actions">
            <button id="share-confirm-cancel" class="delete-btn secondary">Cancel</button>
            <button id="share-confirm-continue" class="delete-btn danger">Share</button>
        </div>
    </div>
</div>

<!-- Delete confirmation modal -->
<div id="delete-confirm-overlay" class="delete-confirm-overlay hidden" role="dialog" aria-modal="true" aria-labelledby="delete-confirm-title">
    <div class="delete-confirm-modal">
        <h3 id="delete-confirm-title">Delete recipes?</h3>
        <p class="delete-confirm-subtitle">This will permanently remove the following recipes from your pantry:</p>
        <ul id="delete-confirm-list" class="delete-confirm-list"></ul>
        <div class="delete-confirm-actions">
            <button id="delete-confirm-cancel" class="delete-btn secondary">Cancel</button>
            <button id="delete-confirm-continue" class="delete-btn danger">Delete</button>
        </div>
    </div>
</div>

<div id="bulk-action-bar" class="bulk-action-bar" aria-live="polite">
    <span id="bulk-selected-count" class="bulk-selected-count">0 recipes selected</span>
    <div class="bulk-kbd-hints">
        <kbd>Ctrl+Shift+Click</kbd> range &nbsp;·&nbsp; <kbd>Ctrl+A</kbd> all
    </div>
    <div class="bulk-action-buttons">
        <button id="bulk-tag-btn" class="bulk-action-btn" title="Add tag">Tag</button>
        <button id="bulk-share-btn" class="bulk-action-btn" title="Share">Share</button>
        <button id="bulk-delete-btn" class="bulk-action-btn danger" title="Delete selected">Delete</button>
    </div>
    <div id="bulk-tag-editor" class="bulk-tag-editor hidden">
        <div class="bulk-tag-input-wrap">
            <div id="bulk-tag-chips" class="bulk-tag-chips"></div>
            <input id="bulk-tag-input" type="text" placeholder="Type tags..." autocomplete="off" />
            <div id="bulk-tag-suggestions" class="bulk-tag-suggestions hidden"></div>
        </div>
        <button id="bulk-tag-apply" class="bulk-action-btn" title="Apply tags">Apply</button>
        <button id="bulk-tag-cancel" class="bulk-action-btn" title="Cancel tag edit">Cancel</button>
    </div>
</div>
