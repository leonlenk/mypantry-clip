---
import feather from "feather-icons";
import Dropdown from "../common/Dropdown.astro";
const searchIcon =
    feather.icons["search"]?.toSvg({ width: 18, height: 18 }) || "";
const clearIcon = feather.icons["x"]?.toSvg({ width: 18, height: 18 }) || "";
const downloadIcon =
    feather.icons["download"]?.toSvg({ width: 16, height: 16 }) || "";
const uploadIcon =
    feather.icons["upload"]?.toSvg({ width: 16, height: 16 }) || "";
---

<header class="top-bar">
    <div class="top-row">
        <!-- LEFT: Primary filters -->
        <div class="left-section">
            <nav class="filters">
                <button class="filter-btn" data-filter="all">All</button>
                <button class="filter-btn" data-filter="recent">Recent</button>
                <button class="filter-btn" data-filter="favorites"
                    >Favorites</button
                >
            </nav>
        </div>

        <!-- CENTER: Search bar + recipe count underneath -->
        <div class="center-section">
            <div class="search-wrap">
                <span class="search-icon" set:html={searchIcon}></span>
                <input
                    type="text"
                    id="semantic-search"
                    placeholder="Semantic search: e.g. 'A spicy high-protein dinner'..."
                />
                <button
                    id="clear-search"
                    class="clear-btn"
                    title="Clear search"
                >
                    <span set:html={clearIcon}></span>
                </button>
                <button class="primary" id="search-btn">Search</button>
            </div>
            <div class="count-wrap">
                <span id="recipe-count" class="recipe-count"></span>
            </div>
        </div>

        <!-- RIGHT: Tag Dropdown -->
        <div class="right-section">
            <input
                type="file"
                id="import-file"
                accept=".json"
                style="display: none;"
            />
            <button
                id="import-btn"
                class="action-btn"
                title="Import Backup"
                set:html={uploadIcon}></button>
            <button
                id="export-btn"
                class="action-btn"
                title="Export Backup"
                set:html={downloadIcon}></button>
            <Dropdown
                id="tag-dropdown"
                label="All Tags"
                placeholderId="selected-tag"
            />
        </div>
    </div>
</header>
