---
import feather from "feather-icons";
import Dropdown from "../common/Dropdown.astro";
const downloadIcon =
    feather.icons["download"]?.toSvg({ width: 16, height: 16 }) || "";
const uploadIcon =
    feather.icons["upload"]?.toSvg({ width: 16, height: 16 }) || "";
const plusIcon =
    feather.icons["plus"]?.toSvg({ width: 16, height: 16 }) || "";

// File-explorer-style view icons (inline SVG for precise control)
const largeViewIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="8" height="8"/><rect x="13" y="3" width="8" height="8"/><rect x="3" y="13" width="8" height="8"/><rect x="13" y="13" width="8" height="8"/></svg>`;
const mediumViewIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="5" height="5"/><rect x="10" y="3" width="5" height="5"/><rect x="17" y="3" width="5" height="5"/><rect x="3" y="10" width="5" height="5"/><rect x="10" y="10" width="5" height="5"/><rect x="17" y="10" width="5" height="5"/><rect x="3" y="17" width="5" height="5"/><rect x="10" y="17" width="5" height="5"/><rect x="17" y="17" width="5" height="5"/></svg>`;
const listViewIcon = feather.icons["list"]?.toSvg({ width: 15, height: 15 }) || "";
---

<header class="top-bar">
    <div class="top-row">
        <!-- LEFT: Primary filters -->
        <div class="left-section">
            <nav class="filters">
                <button class="filter-btn" data-filter="all">All</button>
                <button class="filter-btn" data-filter="recent">Recent</button>
                <button class="filter-btn" data-filter="favorites"
                    >Favorites</button
                >
            </nav>
            <Dropdown
                id="pantry-unit-pref"
                label="US"
                className="left-aligned pantry-unit-dropdown"
                initialValue="us"
                items={[
                    { value: "us", label: "US" },
                    { value: "metric", label: "MET" },
                ]}
            />
            <span class="unit-pref-note">Default Units</span>

            <div class="view-switcher" id="view-switcher">
                <button class="view-mode-btn" data-view="large" title="Large grid" set:html={largeViewIcon}></button>
                <button class="view-mode-btn" data-view="medium" title="Medium grid" set:html={mediumViewIcon}></button>
                <button class="view-mode-btn" data-view="small" title="List view" set:html={listViewIcon}></button>
            </div>
        </div>

        <!-- RIGHT: Actions -->
        <div class="right-section">
            <input
                type="file"
                id="import-file"
                accept=".json"
                style="display: none;"
            />
            <button
                id="import-btn"
                class="action-btn"
                title="Import Backup"
                set:html={uploadIcon}></button>
            <button
                id="export-btn"
                class="action-btn"
                title="Export Backup"
                set:html={downloadIcon}></button>
            <a
                href="recipe-edit.html"
                class="btn primary new-recipe-btn"
                title="Create new recipe"
                set:html={`${plusIcon} New Recipe`}></a>
        </div>
    </div>
</header>
