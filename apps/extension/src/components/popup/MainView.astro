---
import ByokForm from "../shared/ByokForm.astro";
---

<main class="popup-container" id="main-view">
    <header>
        <div
            style="display: flex; justify-content: space-between; align-items: start;"
        >
            <div>
                <h1>Pantry Clip</h1>
                <p>Your intelligent culinary assistant</p>
            </div>
            <div style="display: flex; gap: 4px;">
                <button
                    id="settings-btn"
                    class="text-btn hidden"
                    style="background: none; border: none; cursor: pointer; padding: 4px; color: var(--color-text-muted);"
                    aria-label="Settings"
                >
                    <i
                        data-feather="settings"
                        style="width: 16px; height: 16px;"></i>
                </button>
                <button
                    id="logout-btn"
                    class="text-btn"
                    style="font-size: 0.8rem; color: var(--color-text-muted); text-decoration: underline; background: none; border: none; cursor: pointer; padding: 4px;"
                >
                    Log Out
                </button>
            </div>
        </div>
    </header>

    <section class="action-card card">
        <h3>Current Page</h3>
        <p>Found a recipe on this page?</p>
        <button class="primary" id="extract-btn">Extract & Add to Pantry</button
        >
        <div id="password-container" class="hidden mt">
            <input
                type="password"
                id="popup-password"
                placeholder="Enter your master password"
            />
            <button class="primary mt" id="confirm-extract-btn"
                >Confirm Extraction</button
            >

            <div id="status-viewport" class="status-viewport hidden mt">
                <div id="status-badge" class="status-badge"></div>
                <div
                    id="safe-to-close-msg"
                    class="hidden"
                    style="margin-top: 12px; font-size: 0.75rem; color: var(--color-text-muted); text-align: center; line-height: 1.4;"
                >
                    You can safely close this popup and the active tab now while
                    it finishes in the background.
                </div>
            </div>

            <div id="error-container" class="hidden mt">
                <div
                    id="error-details"
                    style="font-size: 0.75rem; color: #ef4444; margin-top: 0.5rem; background: rgba(239, 68, 68, 0.1); padding: 0.5rem; border-radius: 4px; text-align: left; max-height: 100px; overflow-y: auto; word-break: break-all;"
                >
                </div>
            </div>
        </div>
        <button class="btn mt" id="open-pantry-btn" style="width: 100%;">
            Open Pantry
        </button>
        <button class="btn mt" id="visit-homepage-btn" style="width: 100%;">
            Visit mypantry.dev
        </button>
    </section>

    <!-- Settings Auth Panel -->
    <section class="settings-auth-card card hidden" id="settings-auth-panel">
        <div style="display: flex; align-items: center; margin-bottom: 12px;">
            <button
                id="btn-back-settings-auth"
                class="text-btn"
                style="background: none; border: none; cursor: pointer; padding: 4px; margin-right: 8px; color: var(--color-text-muted);"
            >
                <i data-feather="arrow-left" style="width: 18px; height: 18px;"
                ></i>
            </button>
            <h3 style="margin: 0; font-size: 1.1rem;">Unlock Settings</h3>
        </div>
        <p
            style="font-size: 0.9rem; margin-bottom: 12px; color: var(--color-text-muted);"
        >
            Enter your Master Password to access your Configuration.
        </p>

        <div style="margin-bottom: var(--spacing-sm);">
            <input
                type="password"
                id="input-settings-auth-password"
                placeholder="Enter password..."
                style="width: 100%; padding: 10px; border: 1px solid var(--color-border); border-radius: var(--radius-sm); background-color: var(--color-bg);"
            />
        </div>

        <button
            class="primary"
            id="btn-submit-settings-auth"
            style="width: 100%; margin-top: var(--spacing-md);"
        >
            Unlock Settings
        </button>
        <div
            id="settings-auth-status"
            style="margin-top: 8px; font-size: 0.85rem; text-align: center; color: #ef4444;"
            class="hidden"
        >
        </div>
    </section>

    <!-- Settings Panel (Hidden by default) -->
    <section class="settings-card card hidden" id="settings-panel">
        <div style="display: flex; align-items: center; margin-bottom: 12px;">
            <button
                id="btn-back-settings"
                class="text-btn"
                style="background: none; border: none; cursor: pointer; padding: 4px; margin-right: 8px; color: var(--color-text-muted);"
            >
                <i data-feather="arrow-left" style="width: 18px; height: 18px;"
                ></i>
            </button>
            <h3 style="margin: 0; font-size: 1.1rem;">Settings (BYOK)</h3>
        </div>

        <ByokForm idPrefix="popup-byok-" showPassword={false} />
    </section>
</main>

<script>
    import feather from "feather-icons";
    feather.replace();
</script>
