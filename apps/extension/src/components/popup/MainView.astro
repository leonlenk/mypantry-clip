---
---

<main class="popup-container" id="main-view">
    <header>
        <div
            style="display: flex; justify-content: space-between; align-items: start;"
        >
            <div>
                <h1>Recipe AI</h1>
                <p>Your intelligent culinary assistant</p>
            </div>
            <button
                id="settings-btn"
                class="icon-button"
                aria-label="Settings"
                title="Extension Settings"
            >
                ⚙️
            </button>
        </div>
    </header>

    <section class="action-card card">
        <h3>Current Page</h3>
        <p>Found a recipe on this page?</p>
        <button class="primary" id="extract-btn">Extract & Add to Pantry</button
        >
        <div id="password-container" class="hidden mt">
            <input
                type="password"
                id="popup-password"
                placeholder="Enter your master password"
            />
            <button class="primary mt" id="confirm-extract-btn"
                >Confirm Extraction</button
            >

            <div id="status-viewport" class="status-viewport hidden mt">
                <div id="status-scroller" class="status-scroller">
                    <!-- Status messages will be appended here -->
                </div>
            </div>

            <div id="error-container" class="hidden mt text-center">
                <button
                    id="error-expand-btn"
                    class="text-btn"
                    style="font-size: 0.75rem; text-decoration: underline; background: none; border: none; color: var(--color-text-muted); cursor: pointer;"
                    >Show Details</button
                >
                <div
                    id="error-details"
                    class="hidden"
                    style="font-size: 0.75rem; color: #ef4444; margin-top: 0.5rem; background: rgba(239, 68, 68, 0.1); padding: 0.5rem; border-radius: 4px; text-align: left; max-height: 100px; overflow-y: auto; word-break: break-all;"
                >
                </div>
            </div>
        </div>
        <button class="btn mt" id="open-pantry-btn" style="width: 100%;">
            Open My Pantry
        </button>
    </section>
</main>
