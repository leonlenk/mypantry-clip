{
    "name": "mypantry",
    "private": true,
    "scripts": {
        "api:dev": "cd apps/api && uv run uvicorn main:app --reload --port 8000",
        "api:test": "cd apps/api && uv run pytest ../../tests/api -v",
        "api:kill": "fuser -k 8000/tcp || true",
        "ext:dev": "pnpm --filter mypantry dev",
        "ext:build": "pnpm --filter mypantry build",
        "ext:test": "pnpm --filter mypantry test:unit",
        "ext:test:firefox": "pnpm --filter mypantry test:firefox",
        "ext:test:chromium": "pnpm --filter mypantry test:chromium",
        "ext:zip": "cd apps/extension && zip -r my-pantry.zip dist/",
        "test": "pnpm run api:test && pnpm run ext:test",
        "db:push": "pnpm exec supabase db push",
        "db:reset": "pnpm exec supabase db reset",
        "db:status": "pnpm exec supabase status"
    },
    "engines": {
        "node": ">=18"
    },
    "devDependencies": {
        "supabase": "^2.76.15"
    }
}